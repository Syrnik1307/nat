# Shell scripts must always use LF line endings (Linux/macOS)
*.sh text eol=lf

# Python scripts
*.py text eol=lf

# Docker files
Dockerfile text eol=lf

# Config files that go to Linux servers
*.conf text eol=lf
*.service text eol=lf
*.env text eol=lf

# Windows-specific scripts get CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
