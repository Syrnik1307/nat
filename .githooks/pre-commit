#!/bin/sh
# Guard: block commits on wrong branch + ban tenant code + multi-agent checks
# Allowed branches: new-prod (production), staging (staging environment)
ALLOWED_BRANCHES="new-prod staging"
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null)

IS_ALLOWED=0
for branch in $ALLOWED_BRANCHES; do
    if [ "$CURRENT_BRANCH" = "$branch" ]; then
        IS_ALLOWED=1
        break
    fi
done

if [ "$IS_ALLOWED" = "0" ]; then
    echo "" >&2
    echo "BLOCKED: Commits only allowed on: $ALLOWED_BRANCHES" >&2
    echo "Current branch: $CURRENT_BRANCH" >&2
    echo "To switch: git checkout new-prod" >&2
    echo "To bypass: git commit --no-verify" >&2
    echo "" >&2
    exit 1
fi

# Ban tenant code in staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
if [ -n "$STAGED" ]; then
    TENANT_FILES=$(echo "$STAGED" | grep -i "tenant" 2>/dev/null || true)
    if [ -n "$TENANT_FILES" ]; then
        echo "BLOCKED: Files with tenant in name!" >&2
        echo "$TENANT_FILES" >&2
        exit 1
    fi
fi

# ── Multi-Agent Checks (6 agents) ──
# Runs agent_checks.py on staged files. Exit 1 = BLOCK findings.
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
AGENT_SCRIPT="$REPO_ROOT/scripts/agent_checks.py"
if [ -f "$AGENT_SCRIPT" ]; then
    # Find python
    if [ -f "$REPO_ROOT/.venv/Scripts/python.exe" ]; then
        PY="$REPO_ROOT/.venv/Scripts/python.exe"
    elif [ -f "$REPO_ROOT/venv/Scripts/python.exe" ]; then
        PY="$REPO_ROOT/venv/Scripts/python.exe"
    elif [ -f "$REPO_ROOT/.venv/bin/python" ]; then
        PY="$REPO_ROOT/.venv/bin/python"
    elif [ -f "$REPO_ROOT/venv/bin/python" ]; then
        PY="$REPO_ROOT/venv/bin/python"
    else
        PY="python"
    fi

    echo "[pre-commit] Running multi-agent checks..." >&2
    "$PY" "$AGENT_SCRIPT" --staged
    AGENT_EXIT=$?
    if [ "$AGENT_EXIT" = "1" ]; then
        echo "" >&2
        echo "BLOCKED by agent checks. Fix BLOCK issues above." >&2
        echo "To bypass: git commit --no-verify" >&2
        exit 1
    fi
fi
