# ======================
# Teaching Panel
# STAGING .env Template
# ======================
# Copy to /var/www/teaching-panel-stage/.env
# NEVER commit actual .env to git!

# ======================
# Django Core
# ======================
SECRET_KEY=staging-change-me-to-random-string
DEBUG=True
ALLOWED_HOSTS=stage.lectiospace.ru,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=teaching_panel.settings_staging

# ======================
# Database (separate from prod!)
# ======================
# Option A: Separate PostgreSQL DB
DATABASE_URL=postgresql://staging_user:staging_password@localhost:5432/teaching_panel_staging
# Option B: SQLite (simpler, good enough for staging)
# Unset DATABASE_URL to use SQLite: teaching_panel/db.sqlite3

# ======================
# Redis & Celery (separate DB numbers from prod!)
# Prod uses /0 and /1, staging uses /2 and /3
# ======================
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
REDIS_URL=redis://127.0.0.1:6379/3

# ======================
# Frontend
# ======================
FRONTEND_URL=https://stage.lectiospace.ru
CSRF_TRUSTED_ORIGINS=https://stage.lectiospace.ru

# ======================
# Email (console for staging)
# ======================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ======================
# Zoom API (leave empty for mock mode on staging)
# ======================
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_WEBHOOK_SECRET_TOKEN=

# ======================
# YooKassa (leave empty for mock mode on staging)
# ======================
# YOOKASSA_ACCOUNT_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_WEBHOOK_SECRET=

# ======================
# reCAPTCHA (disabled on staging)
# ======================
RECAPTCHA_ENABLED=false

# ======================
# Security (relaxed for staging)
# ======================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
